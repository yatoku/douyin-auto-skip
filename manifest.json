{
  "manifest_version": 3,
  "name": "抖音自动跳过",
  "version": "1.0.0",
  "description": "自动跳过抖音PC网页版的广告、购物和直播视频，刷到下一个",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*.douyin.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.douyin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "抖音自动跳过"
  }
}